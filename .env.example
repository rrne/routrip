# Supabase — https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용. 절대 클라이언트 코드에서 사용 금지.
SUPABASE_SERVICE_ROLE_KEY=

# Kakao Developers — https://developers.kakao.com/console/app
# JavaScript 키: 국내 모드의 지도 SDK + Local 검색 처리.
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=

# Google Maps Platform — https://console.cloud.google.com
# Maps JavaScript API + Places API (New) 활성화 + HTTP referrer로 도메인 제한 권장.
# 해외 모드 지도 + 검색용.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
